---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout title="Contact" description="Get in touch with The Automation Foundry. Let's talk about your automation needs.">
  <section class="py-20 md:py-28">
    <div class="max-w-3xl mx-auto px-6">
      <p class="text-sm uppercase tracking-widest text-[var(--color-accent)] mb-4">Contact</p>
      <h1 class="text-4xl md:text-5xl font-bold leading-tight mb-6">
        Let's build something together.
      </h1>
      <p class="text-lg text-muted max-w-2xl mb-12">
        Have a project in mind? Want to learn how automation can help your team?
        Drop us a message and we'll get back to you.
      </p>

      <ContactForm />
    </div>
  </section>
</BaseLayout>
