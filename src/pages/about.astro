---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About" description="Learn about The Automation Foundry — our story, mission, and approach.">
  <section class="py-20 md:py-28">
    <div class="max-w-3xl mx-auto px-6">
      <p class="text-sm uppercase tracking-widest text-[var(--color-accent)] mb-4">About</p>
      <h1 class="text-4xl md:text-5xl font-bold leading-tight">
        Building the future of work, one automation at a time.
      </h1>
      <p class="mt-6 text-lg text-muted leading-relaxed">
        The Automation Foundry was founded on a simple belief: businesses
        shouldn't waste human potential on tasks that machines can handle better.
      </p>
    </div>
  </section>

  <div class="max-w-3xl mx-auto px-6">
    <hr class="border-subtle" />
  </div>

  <section class="py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-6 space-y-12">
      <div>
        <h2 class="text-2xl font-bold mb-4">Our Story</h2>
        <div class="text-muted leading-relaxed space-y-4">
          <p>
            We started The Automation Foundry after years of watching talented teams
            burn out on repetitive work. Data entry, report generation, manual
            integrations — brilliant people spending their days on tasks that could
            be automated in weeks.
          </p>
          <p>
            So we built a company dedicated to changing that. We partner with
            businesses to identify bottlenecks, design intelligent workflows, and
            implement automation solutions that actually work in the real world.
          </p>
        </div>
      </div>

      <div>
        <h2 class="text-2xl font-bold mb-4">Our Mission</h2>
        <p class="text-muted leading-relaxed">
          To free teams from repetitive work so they can focus on what humans do
          best: creative problem-solving, building relationships, and driving
          innovation. We believe automation should amplify human capability, not
          replace it.
        </p>
      </div>

      <div>
        <h2 class="text-2xl font-bold mb-4">Our Approach</h2>
        <div class="grid md:grid-cols-3 gap-8">
          <div>
            <h3 class="font-bold text-[var(--color-accent)] mb-2">Discover</h3>
            <p class="text-sm text-muted leading-relaxed">
              We map your workflows, identify bottlenecks, and find the highest-impact
              automation opportunities.
            </p>
          </div>
          <div>
            <h3 class="font-bold text-[var(--color-accent)] mb-2">Design</h3>
            <p class="text-sm text-muted leading-relaxed">
              We architect solutions that integrate with your existing tools and scale
              with your business.
            </p>
          </div>
          <div>
            <h3 class="font-bold text-[var(--color-accent)] mb-2">Deliver</h3>
            <p class="text-sm text-muted leading-relaxed">
              We build, test, and deploy automation that works reliably — then train
              your team to own it.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
