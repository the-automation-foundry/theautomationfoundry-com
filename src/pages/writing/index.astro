---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());
---

<BaseLayout title="Writing" description="Thoughts on automation, technology, and building better systems.">
  <section class="py-20 md:py-28">
    <div class="max-w-3xl mx-auto px-6">
      <p class="text-sm uppercase tracking-widest text-[var(--color-accent)] mb-4">Writing</p>
      <h1 class="text-4xl md:text-5xl font-bold leading-tight mb-6">
        Ideas & Insights
      </h1>
      <p class="text-lg text-muted max-w-2xl">
        Thoughts on automation, technology, and building systems that work.
      </p>
    </div>
  </section>

  <section class="pb-20 md:pb-28">
    <div class="max-w-3xl mx-auto px-6">
      {posts.length > 0 ? (
        posts.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
            slug={post.id}
          />
        ))
      ) : (
        <p class="text-muted">Posts coming soon.</p>
      )}
    </div>
  </section>
</BaseLayout>
