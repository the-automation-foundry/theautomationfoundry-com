---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allWriting = await getCollection('writing', ({ data }) => !data.draft);
const latestWriting = allWriting
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 3);

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const displayProjects = featuredProjects.length > 0
  ? featuredProjects
  : allProjects
      .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
      .slice(0, 3);
---

<BaseLayout>
  <!-- Hero / Intro -->
  <section class="py-20 md:py-28">
    <div class="max-w-4xl mx-auto px-6">
      <p class="text-sm uppercase tracking-widest text-[var(--color-accent)] mb-4">The Automation Foundry</p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight">
        We build systems that<br />work while you sleep.
      </h1>
      <p class="mt-6 text-lg md:text-xl text-muted leading-relaxed max-w-2xl">
        The Automation Foundry designs and builds custom automation solutions
        that transform how businesses operate. From workflow automation to
        intelligent data pipelines, we help teams reclaim their time.
      </p>
      <a
        href="/contact"
        class="inline-block mt-8 px-6 py-3 bg-[var(--color-accent)] text-white rounded-lg font-medium text-sm uppercase tracking-wide hover:bg-[var(--color-accent-hover)] transition-colors"
      >
        Get in Touch
      </a>
    </div>
  </section>

  <!-- Divider -->
  <div class="max-w-6xl mx-auto px-6">
    <hr class="border-subtle" />
  </div>

  <!-- Featured Projects -->
  {displayProjects.length > 0 && (
    <section class="py-20 md:py-24">
      <div class="max-w-6xl mx-auto px-6">
        <div class="flex items-center justify-between mb-12">
          <h2 class="text-2xl md:text-3xl font-bold">Featured Projects</h2>
          <a href="/projects" class="text-sm text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] uppercase tracking-wide transition-colors">
            View All &rarr;
          </a>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {displayProjects.map((project) => (
            <ProjectCard
              title={project.data.title}
              description={project.data.description}
              image={project.data.image}
              imageAlt={project.data.imageAlt}
              tags={project.data.tags}
              slug={project.id}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Divider -->
  <div class="max-w-6xl mx-auto px-6">
    <hr class="border-subtle" />
  </div>

  <!-- Latest Writing -->
  {latestWriting.length > 0 && (
    <section class="py-20 md:py-24">
      <div class="max-w-3xl mx-auto px-6">
        <div class="flex items-center justify-between mb-12">
          <h2 class="text-2xl md:text-3xl font-bold">Latest Writing</h2>
          <a href="/writing" class="text-sm text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] uppercase tracking-wide transition-colors">
            View All &rarr;
          </a>
        </div>
        {latestWriting.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
            slug={post.id}
          />
        ))}
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="py-20 md:py-28 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="text-3xl md:text-4xl font-bold">Ready to automate?</h2>
      <p class="mt-4 text-lg text-muted">
        Let's talk about how automation can transform your business.
      </p>
      <a
        href="/contact"
        class="inline-block mt-8 px-6 py-3 bg-[var(--color-accent)] text-white rounded-lg font-medium text-sm uppercase tracking-wide hover:bg-[var(--color-accent-hover)] transition-colors"
      >
        Start a Conversation
      </a>
    </div>
  </section>
</BaseLayout>
