---
const pathname = Astro.url.pathname;
const links = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/projects', label: 'Projects' },
  { href: '/writing', label: 'Writing' },
  { href: '/contact', label: 'Contact' },
];

function isActive(href: string) {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<nav class="hidden md:flex items-center gap-8">
  {links.map((link) => (
    <a
      href={link.href}
      class:list={[
        'text-sm tracking-wide uppercase transition-colors',
        isActive(link.href)
          ? 'text-[var(--color-accent)]'
          : 'text-muted hover:text-[var(--color-accent)]',
      ]}
    >
      {link.label}
    </a>
  ))}
</nav>

<!-- Mobile nav -->
<nav id="mobile-nav" class="hidden fixed inset-0 z-50 bg-[var(--color-bg-dark)] flex-col items-center justify-center gap-8">
  <button id="mobile-nav-close" class="absolute top-6 right-6 p-2" aria-label="Close menu">
    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>
  {links.map((link) => (
    <a
      href={link.href}
      class:list={[
        'text-xl tracking-wide uppercase transition-colors',
        isActive(link.href)
          ? 'text-[var(--color-accent)]'
          : 'text-muted hover:text-[var(--color-accent)]',
      ]}
    >
      {link.label}
    </a>
  ))}
</nav>

<script is:inline>
  (function() {
    const mobileNav = document.getElementById('mobile-nav');
    const lightClass = document.documentElement.classList.contains('light');
    if (lightClass) {
      mobileNav.style.backgroundColor = 'var(--color-bg-light)';
    }
  })();
</script>
