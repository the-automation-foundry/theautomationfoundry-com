---
interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
}

const {
  title = 'The Automation Foundry',
  description = 'We build automation solutions that transform how businesses operate.',
  image = '/images/og-default.png',
  type = 'website',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://theautomationfoundry.com');
const fullTitle = title === 'The Automation Foundry' ? title : `${title} | The Automation Foundry`;
---

<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={image} />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={image} />
