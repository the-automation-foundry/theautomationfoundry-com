---
interface Props {
  variant?: 'lockup' | 'icon';
  theme?: 'light' | 'dark' | 'primary';
  width?: number;
  class?: string;
  ariaLabel?: string;
}

const {
  variant = 'lockup',
  theme = 'light',
  width,
  class: className = '',
  ariaLabel = 'The Automation Foundry',
} = Astro.props;

// Stroke + hatch colors per the brand guide:
// - On light bg: Ink stroke, Current hatch
// - On dark bg:  Limestone stroke, Copper hatch
// - On primary:  Limestone stroke, Copper hatch
const isLightBg = theme === 'light';
const strokeColor = isLightBg ? '#262B2E' : '#F0EFEB';
const hatchColor = isLightBg ? '#4E6A78' : '#BF7E4A';
const wordmarkColor = isLightBg ? '#262B2E' : '#F0EFEB';
const badgeColor = isLightBg ? '#4E6A78' : '#BF7E4A';
const badgeTextColor = isLightBg ? '#F0EFEB' : '#262B2E';

const uid = Math.random().toString(36).slice(2, 9);
const lockupWidth = width ?? 200;
const iconWidth = width ?? 48;
