    viewBox="0 0 357 120"
    width={lockupWidth}
    role="img"
    aria-label={ariaLabel}
    class={className}
  >
    <defs>
      <pattern id={`hatch-${uid}`} patternUnits="userSpaceOnUse" width="5" height="5" patternTransform="rotate(60)">
        <line x1="0" y1="0" x2="0" y2="5" stroke={hatchColor} stroke-width="3" />
