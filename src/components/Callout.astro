---
interface Props {
  type?: 'info' | 'success' | 'warning' | 'error';
}

const { type = 'info' } = Astro.props;

const styles = {
  info: { emoji: 'ℹ️', bg: 'bg-blue-500/10', border: 'border-blue-500/30', text: 'text-blue-400' },
  success: { emoji: '✅', bg: 'bg-green-500/10', border: 'border-green-500/30', text: 'text-green-400' },
  warning: { emoji: '⚠️', bg: 'bg-yellow-500/10', border: 'border-yellow-500/30', text: 'text-yellow-400' },
  error: { emoji: '🚫', bg: 'bg-red-500/10', border: 'border-red-500/30', text: 'text-red-400' },
};

const s = styles[type];
---

<aside class={`${s.bg} border ${s.border} rounded-lg p-4 my-6`}>
  <div class="flex gap-3">
    <span class="text-lg flex-shrink-0">{s.emoji}</span>
    <div class={`${s.text} prose-sm`}>
      <slot />
    </div>
  </div>
</aside>
