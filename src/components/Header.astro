---
import Logo from './Logo.astro';
import ThemeToggle from './ThemeToggle.astro';

// One-page launch (v1): nav stripped to just the logo + theme toggle.
// To restore multi-page nav, uncomment the <Nav /> import + render below
// and re-enable links in src/components/Nav.astro.
// import Nav from './Nav.astro';
---

<header class="w-full border-b border-subtle backdrop-blur-md sticky top-0 z-50" style="background: color-mix(in srgb, var(--color-bg) 88%, transparent);">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between gap-6">
    <a href="/" class="block leading-none" aria-label="The Automation Foundry — Home">
      <Logo variant="lockup" theme="light" width={180} class="light-only" />
      <Logo variant="lockup" theme="dark" width={180} class="dark-only" />
    </a>

    <div class="flex items-center gap-3">
      {/* <Nav /> */}
      <ThemeToggle />
    </div>
  </div>
</header>
