---
interface Props {
  title: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  tags?: string[];
  slug: string;
}

const { title, description, image, imageAlt, tags = [], slug } = Astro.props;
---

<article class="group rounded-xl border border-subtle overflow-hidden bg-surface transition-all hover:border-[var(--color-accent)]/30">
  <a href={`/projects/${slug}`} class="block">
    {image && (
      <div class="aspect-video overflow-hidden">
        <img
          src={image}
          alt={imageAlt || title}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          loading="lazy"
        />
      </div>
    )}
    <div class="p-6">
      <h3 class="text-lg font-bold group-hover:text-[var(--color-accent)] transition-colors">
        {title}
      </h3>
      {description && (
        <p class="mt-2 text-sm text-muted leading-relaxed line-clamp-2">{description}</p>
      )}
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {tags.map((tag) => (
            <span class="text-xs uppercase tracking-wider px-2 py-0.5 rounded-full bg-[var(--color-accent)]/10 text-[var(--color-accent)]">
              {tag}
            </span>
          ))}
        </div>
      )}
    </div>
  </a>
</article>
